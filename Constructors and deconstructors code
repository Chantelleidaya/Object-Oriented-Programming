class Student:
    def __init__(self, name, grade):
        self.name = name
        self.grade = grade
        print(f"Student {self.name} created!")

    def show_info(self):
        print(f"{self.name} is in grade {self.grade}")

    def __del__(self):
        print(f"Student {self.name} removed")


# Using it
s1 = Student("Aisha", 10)     # constructor runs
s1.show_info()

s2 = Student("Jamal", 8)

del s1                        # destructor may run here

# s2 will be destroyed when program ends
