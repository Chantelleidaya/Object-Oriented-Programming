Example 2 – Phone (with a small cleanup message)
Pythonclass Phone:
    def __init__(self, brand, battery):
        self.brand = brand
        self.battery = battery
        print(f"New {self.brand} phone created with {self.battery}% battery")

    def charge(self):
        self.battery = 100
        print(f"{self.brand} phone charged to 100%")

    def __del__(self):
        print(f"{self.brand} phone is now destroyed")


p1 = Phone("Samsung", 45)
p1.charge()

p2 = Phone("iPhone", 80)

del p1
